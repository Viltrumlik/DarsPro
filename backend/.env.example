# Django
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database (Docker Compose db servisi bilan mos)
DATABASE_URL=postgres://darspro:darspro@db:5432/darspro

# Redis (channel layer + cache + Celery broker)
REDIS_URL=redis://redis:6379/0

# Celery (bo'sh bo'lsa REDIS_URL ishlatiladi)
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# CORS (frontend manzili)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT token muddati (daqiqa / kun)
ACCESS_TOKEN_LIFETIME_MIN=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# Logging
# LOG_LEVEL=INFO
# LOG_FORMAT=text          # "json" -> strukturali log

# Media upload (MB)
# MAX_UPLOAD_MB=5

# Media storage — prod uchun S3-mos (USE_S3=True bo'lganda yoqiladi).
# Bo'sh qoldirilsa lokal fayl tizimi ishlatiladi (dev).
# USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=
# S3-mos provayderlar uchun (MinIO/Wasabi/DO Spaces):
# AWS_S3_ENDPOINT_URL=
# AWS_S3_CUSTOM_DOMAIN=
# AWS_QUERYSTRING_AUTH=False

# Email — dev'da console backend (terminalga chiqaradi). Prod uchun SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=DarsPro <no-reply@darspro.uz>

# Auth provayderlari (bo'sh bo'lsa tegishli endpoint 503 qaytaradi)
# GOOGLE_CLIENT_ID=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=
# SMS_PROVIDER=console            # console | eskiz
# ESKIZ_EMAIL=
# ESKIZ_PASSWORD=
# SMS_FROM=4546
# OTP_TTL_SEC=300

# Observability (ixtiyoriy)
# SENTRY_DSN=
# SENTRY_TRACES_RATE=0.0
